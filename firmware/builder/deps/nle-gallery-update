#!/bin/sh
# nle-gallery-update: Fetch/update gallery images from web server
# Usage: nle-gallery-update [gallery-url] [photo-dir]

GALLERY_URL="${1:-http://nest-gallery.jasongraphix.com}"
PHOTO_DIR="${2:-/media/scratch/nle-photos}"
FETCH="/usr/bin/nle-fetch"
MANIFEST="/tmp/gallery-manifest.txt"

# Ensure DNS works (musl resolver needs a real nameserver)
if ! grep -q "8.8.8.8" /etc/resolv.conf 2>/dev/null; then
    echo "nameserver 8.8.8.8" > /etc/resolv.conf
fi

echo "Fetching manifest from $GALLERY_URL/gallery.txt"
$FETCH "$GALLERY_URL/gallery.txt" "$MANIFEST" 2>&1
if [ ! -f "$MANIFEST" ] || [ ! -s "$MANIFEST" ]; then
    echo "Failed to fetch manifest"
    exit 1
fi

mkdir -p "$PHOTO_DIR"

# Download new or updated images
DOWNLOADED=0
SKIPPED=0
while read -r filename; do
    [ -z "$filename" ] && continue
    dest="$PHOTO_DIR/$filename"
    if [ -f "$dest" ]; then
        # Check size — if it matches 409600 bytes, skip
        size=$(ls -l "$dest" 2>/dev/null | awk '{print $5}')
        if [ "$size" = "409600" ]; then
            SKIPPED=$((SKIPPED + 1))
            continue
        fi
    fi
    # Stop if disk space is low (< 2MB free)
    free_kb=$(df "$PHOTO_DIR" 2>/dev/null | tail -1 | awk '{print $4}')
    if [ -n "$free_kb" ] && [ "$free_kb" -lt 2048 ]; then
        echo "Disk low (${free_kb}KB free), stopping downloads"
        break
    fi
    echo "Downloading $filename..."
    $FETCH "$GALLERY_URL/$filename" "$dest" 2>&1
    if [ -f "$dest" ]; then
        size=$(ls -l "$dest" | awk '{print $5}')
        if [ "$size" = "409600" ]; then
            DOWNLOADED=$((DOWNLOADED + 1))
        else
            echo "  Bad size ($size), removing"
            rm -f "$dest"
        fi
    fi
done < "$MANIFEST"

# Remove images not in manifest
REMOVED=0
for f in "$PHOTO_DIR"/*.raw; do
    [ -f "$f" ] || continue
    base=$(basename "$f")
    if ! grep -q "^${base}$" "$MANIFEST"; then
        echo "Removing $base (not in manifest)"
        rm -f "$f"
        REMOVED=$((REMOVED + 1))
    fi
done

rm -f "$MANIFEST"

echo "Done: $DOWNLOADED downloaded, $SKIPPED unchanged, $REMOVED removed"

# Restart gallery if images changed (only when run manually)
if [ "$DOWNLOADED" -gt 0 ] || [ "$REMOVED" -gt 0 ]; then
    # Check if our parent is nle-gallery — if so, skip restart (it reloads itself)
    PPNAME=""
    if [ -f "/proc/$PPID/comm" ]; then
        PPNAME=$(cat "/proc/$PPID/comm" 2>/dev/null)
    fi
    if [ "$PPNAME" != "nle-gallery" ]; then
        echo "Restarting gallery..."
        kill -9 $(pidof nle-gallery) 2>/dev/null
        sleep 1
        /usr/bin/nle-gallery --takeover "$PHOTO_DIR" /dev/input/event1 > /dev/null 2>&1 &
        echo "Gallery restarted (PID $!)"
    fi
fi
