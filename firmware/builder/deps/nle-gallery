#!/bin/sh
# Photo gallery for Nest Gen 2 LCD
# Fetches images from a static URL and cycles through them on the display

GALLERY_URL="${1:-https://static.jasongraphix.com/nest-photos}"
INTERVAL="${2:-30}"
MANIFEST="/tmp/gallery.txt"

# Freeze heartbeat monitor (prevents reboot when nlclient is unresponsive)
HB_PID=$(ps -A | grep nlheartbeat | grep -v grep | head -1 | cut -c1-6)
[ -n "$HB_PID" ] && kill -STOP $HB_PID

# Freeze Nest UI (SIGSTOP, not kill — killing triggers reboot)
NLC_PID=$(ps -A | grep nlclient | grep -v grep | head -1 | cut -c1-6)
[ -n "$NLC_PID" ] && kill -STOP $NLC_PID

# Wake display and set backlight
echo 0 > /sys/class/graphics/fb0/blank
echo 120 > /sys/class/backlight/3-0036/brightness

while true; do
  busybox2 wget -q -O "$MANIFEST" "${GALLERY_URL}/gallery.txt" 2>/dev/null
  if [ ! -f "$MANIFEST" ]; then
    sleep "$INTERVAL"
    continue
  fi
  while read -r filename; do
    [ -z "$filename" ] && continue
    busybox2 wget -q -O /tmp/current.raw "${GALLERY_URL}/${filename}" 2>/dev/null
    if [ -f /tmp/current.raw ]; then
      cat /tmp/current.raw /tmp/current.raw > /dev/fb0
      rm -f /tmp/current.raw
    fi
    sleep "$INTERVAL"
  done < "$MANIFEST"
  rm -f "$MANIFEST"
done
